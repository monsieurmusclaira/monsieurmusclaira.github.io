---
import { Image } from 'astro:assets';
import { resolveImage } from '../utils/images';
const { image, alt, caption, rotation } = Astro.props;
---
<figure style={rotation}>
    <Image
    src={resolveImage(image)}
    loading="lazy"
    alt={alt}
    />
    <figcaption>{caption}</figcaption>
</figure>