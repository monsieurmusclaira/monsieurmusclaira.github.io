---
import { Image } from 'astro:assets';
import { resolveImage } from '../utils/images';
const { title, img, alt, imageposition, desc, url, badge1, badge2, target = '_self', loading = 'lazy' } = Astro.props;
const slug = url?.split('/').filter(Boolean).pop();
---
<a href={url} target={target}
  class="block h-screen w-screen relative group focus-visible:outline-solid focus-visible:outline-2 focus-visible:outline-offset-[-6px] focus-visible:outline-warning"
  data-aos="fade-up" data-aos-duration="800"
  style="pointer-events: auto;">

  <div class="z-0 h-screen w-screen absolute top-0 overflow-hidden" transition:name={`hero-${slug}`}>
    <Image
      src={resolveImage(img)}
      alt={alt || `${title}, cinematography still by Victor Maes`}
      class="w-full h-full object-cover transition-transform duration-1400 ease-out group-hover:scale-105"
      style={`object-position: ${imageposition || '50% 50%'}`}
      widths={[768, 1440, 2560]}
      sizes="100vw"
      loading={loading}
      fetchpriority={loading === 'eager' ? 'high' : 'auto'}
    />
  </div>

  <svg class="grain absolute top-0 z-10 w-full h-full" aria-hidden="true"></svg>

  <div class="absolute w-screen p-7 sm:p-10 pt-24 sm:pt-32 bottom-0 z-20 bg-linear-to-t from-neutral/85 via-neutral/40 to-transparent transition-all duration-500 group-hover:from-neutral/95">
    <h2 class="text-4xl text-warning font-bold capitalize">{title}</h2>
    <p class="text-base text-base-100 italic mt-1">{desc}</p>
    {(badge1 || badge2) && (
      <p class="mt-3 font-sans text-xs tracking-widest uppercase text-base-100/70">
        {[badge1, badge2].filter(Boolean).join(' · ')}
      </p>
    )}
    <p class="mt-4 text-xs tracking-widest uppercase text-base-100/60 group-hover:text-secondary transition-colors duration-300 font-sans">
      View project <span class="inline-block transition-transform duration-300 group-hover:translate-x-1">&rarr;</span>
    </p>
  </div>
</a>
