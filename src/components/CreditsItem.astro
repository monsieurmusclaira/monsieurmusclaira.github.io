---
const { crewfunction, crewname } = Astro.props;
const isNew = Boolean(crewfunction && crewfunction.trim());
// A new department heading gets extra top spacing to separate groups,
// instead of a divider line (lines looked ragged across the two columns).
const groupGap = isNew ? 'mt-4' : '';
---
<p class={`text-right pr-6 self-center ${groupGap}`}>
  {isNew && (
    <span class="font-sans text-[11px] tracking-widest uppercase text-base-100/40">
      {crewfunction}
    </span>
  )}
</p>
<p class={`font-sans text-base font-light text-base-100/80 py-0.5 ${groupGap}`}>{crewname}</p>
