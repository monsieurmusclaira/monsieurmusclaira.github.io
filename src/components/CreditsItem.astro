---
const { crewfunction, crewname } = Astro.props;
const isNew = Boolean(crewfunction && crewfunction.trim());
---
{isNew && <hr class="col-span-2 border-t border-base-100/10 mt-3" />}
<p class="text-right pr-6 self-center">
  {isNew && (
    <span class="font-sans text-[11px] tracking-widest uppercase text-base-100/40">
      {crewfunction}
    </span>
  )}
</p>
<p class="font-sans text-base font-light text-base-100/80 py-0.5">{crewname}</p>
