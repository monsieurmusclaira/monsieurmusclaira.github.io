---
const { festivalname, heading, spaced } = Astro.props;
const isNew = Boolean(heading && heading.trim());
const hrMargin = spaced ? 'mt-10' : 'mt-3';
---
{isNew && <hr class={`col-span-2 border-t border-base-100/10 ${hrMargin}`} />}
<p class="text-right pr-6 self-center">
  {isNew && (
    <span class="font-sans text-[11px] tracking-widest uppercase text-base-100/40">
      {heading}
    </span>
  )}
</p>
<p class="font-sans text-base font-light text-base-100/80 py-0.5">{festivalname}</p>
