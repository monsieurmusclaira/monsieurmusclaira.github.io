---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import { getImage } from 'astro:assets';
import { GoogleAnalytics } from 'astro-google-analytics';
import { resolveImage } from '../utils/images';
import { SITE_TITLE, SITE_URL } from '../config';

export interface Props {
	title: string;
	description: string;
	image?: string;
	imageAlt?: string;
	canonical?: string;
	schema?: object;
	noindex?: boolean;
	director?: string;
	genre?: string;
	year?: string;
}

const { title, description, image, imageAlt, canonical, schema, noindex, director, genre, year } = Astro.props;

// Social-card image alt: describe the actual photo when the page provides it,
// otherwise fall back to the page title.
const imageAltText = imageAlt || title;

const canonicalURL = canonical ? new URL(canonical, SITE_URL) : new URL(Astro.url.pathname, SITE_URL);

// Social-card image: src/assets paths get optimized to a 1200px JPEG;
// public paths (e.g. /video/seethrough.jpg) pass through as-is.
let ogImage: string | null = null;
if (image) {
  try {
    const optimized = await getImage({ src: resolveImage(image), format: 'jpeg', width: 1200 });
    ogImage = new URL(optimized.src, SITE_URL).toString();
  } catch {
    ogImage = new URL(image, SITE_URL).toString();
  }
}

const pageType = Astro.url.pathname.startsWith('/projects/') ? 'project' 
  : Astro.url.pathname === '/' || Astro.url.pathname === '' ? 'home'
  : Astro.url.pathname.startsWith('/about') ? 'about'
  : Astro.url.pathname.startsWith('/behind-the-scenes') ? 'bts'
  : 'page';

// Build JSON-LD schemas
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": `${SITE_URL}/#person`,
  "name": "Victor Maes",
  "jobTitle": "Cinematographer",
  "description": "Victor Maes is a Cinematographer, Director of Photography and Director from Brussels Belgium",
  "url": SITE_URL,
  "sameAs": [
    "https://www.instagram.com/monsieur_musclaira/",
    "https://www.linkedin.com/in/victor-maes/",
    "https://www.imdb.com/name/nm4866929"
  ],
  "knowsAbout": ["Cinematography", "Film", "Virtual Reality", "Documentary", "Director of Photography"],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Brussels",
    "addressCountry": "BE"
  }
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${SITE_URL}/#website`,
  "name": SITE_TITLE,
  "url": SITE_URL,
  "publisher": {
    "@id": `${SITE_URL}/#person`
  }
};

let pageSchema: object | null = null;

if (pageType === 'home') {
  pageSchema = {
    "@context": "https://schema.org",
    "@type": "ProfilePage",
    "@id": canonicalURL.toString(),
    "url": canonicalURL.toString(),
    "name": title,
    "description": description,
    "mainEntity": {
      "@id": `${SITE_URL}/#person`
    },
    "isPartOf": {
      "@id": `${SITE_URL}/#website`
    }
  };
} else if (pageType === 'project') {
  const projectTitle = title.split(' — ')[0].split(' | ')[0];
  pageSchema = {
    "@context": "https://schema.org",
    "@type": "Movie",
    "@id": canonicalURL.toString(),
    "url": canonicalURL.toString(),
    "name": projectTitle,
    "description": description,
    ...(ogImage ? { "image": ogImage } : {}),
    ...(director ? { "director": director.split(' & ').map((name) => ({ "@type": "Person", "name": name })) } : {}),
    ...(genre ? { "genre": genre } : {}),
    ...(year ? { "datePublished": year } : {}),
    "cinematographer": {
      "@type": "Person",
      "name": "Victor Maes",
      "url": SITE_URL
    },
    "creator": {
      "@id": `${SITE_URL}/#person`
    },
    "isPartOf": {
      "@id": `${SITE_URL}/#website`
    }
  };
} else if (pageType === 'about') {
  pageSchema = {
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "@id": canonicalURL.toString(),
    "url": canonicalURL.toString(),
    "name": title,
    "description": description,
    "mainEntity": {
      "@id": `${SITE_URL}/#person`
    },
    "isPartOf": {
      "@id": `${SITE_URL}/#website`
    }
  };
} else if (pageType === 'bts') {
  pageSchema = {
    "@context": "https://schema.org",
    "@type": "ImageGallery",
    "@id": canonicalURL.toString(),
    "url": canonicalURL.toString(),
    "name": title,
    "description": description,
    ...(ogImage ? { "image": ogImage } : {}),
    "about": {
      "@id": `${SITE_URL}/#person`
    },
    "isPartOf": {
      "@id": `${SITE_URL}/#website`
    }
  };
} else {
  pageSchema = {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": canonicalURL.toString(),
    "url": canonicalURL.toString(),
    "name": title,
    "description": description,
    "isPartOf": {
      "@id": `${SITE_URL}/#website`
    }
  };
}

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": SITE_URL
    },
    ...(pageType !== 'home' ? [{
      "@type": "ListItem",
      "position": 2,
      "name": title.split(' | ')[0].split(' — ')[0],
      "item": canonicalURL.toString()
    }] : [])
  ]
};

const schemas = [personSchema, websiteSchema, pageSchema, breadcrumbSchema];
if (schema) {
  schemas.push(schema);
}
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="generator" content={Astro.generator} />
<meta name="theme-color" content="#000000" />
<meta name="color-scheme" content="dark" />

<!-- Canonical & Hreflang -->
<link rel="canonical" href={canonicalURL} />
<link rel="alternate" hreflang="en" href={canonicalURL} />
<link rel="alternate" hreflang="x-default" href={canonicalURL} />

<!-- LCP preload: hero video poster on home page -->
{pageType === 'home' && <link rel="preload" as="image" href="/video/seethrough.jpg" fetchpriority="high" />}

<!-- Performance: Preconnect -->
<link rel="preconnect" href="https://www.googletagmanager.com" />
<link rel="dns-prefetch" href="https://www.googletagmanager.com" />
<link rel="preconnect" href="https://unpkg.com" crossorigin />
<link rel="dns-prefetch" href="https://unpkg.com" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600&display=swap" media="print" onload="this.media='all'" />
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&display=swap" media="print" onload="this.media='all'" />
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Caveat&display=swap" media="print" onload="this.media='all'" />
<noscript>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600&display=swap" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&display=swap" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Caveat&display=swap" />
</noscript>

<!-- Crawl directives -->
{noindex && <meta name="robots" content="noindex, nofollow" />}

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:locale" content="en_US" />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
{ogImage && (
  <>
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={imageAltText} />
  </>
)}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
{ogImage && (
  <>
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={imageAltText} />
  </>
)}

<!-- Animate On Scroll (non-blocking) -->
<link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" media="print" onload="this.media='all'" />
<noscript><link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" /></noscript>

<!-- JSON-LD Schema -->
<script type="application/ld+json" set:html={JSON.stringify(schemas)} />

<!-- Google Analytics (production builds only — never fires in dev) -->
{import.meta.env.PROD && <GoogleAnalytics id="G-1P80SYF663" />}
