---
const today = new Date();
---

<footer class="bg-neutral border-t border-base-100/10 py-10 px-6 font-['Montserrat']">
  <div class="max-w-4xl mx-auto grid grid-cols-1 sm:grid-cols-3 gap-8 text-xs tracking-widest uppercase text-base-100/60">

    <div class="flex flex-col gap-3">
      <span class="text-base-100/30 text-[10px]">Navigate</span>
      <a href="/" class="hover:text-secondary transition-colors duration-200">Work</a>
      <a href="/about/" class="hover:text-secondary transition-colors duration-200">About</a>
      <a href="/behind-the-scenes/" class="hover:text-secondary transition-colors duration-200">Behind the Scenes</a>
    </div>

    <div class="flex flex-col gap-3">
      <span class="text-base-100/30 text-[10px]">Contact</span>
      <a href="mailto:hello@victormaes.com" class="hover:text-secondary transition-colors duration-200 normal-case">hello@victormaes.com</a>
      <a href="https://www.instagram.com/monsieur_musclaira/" target="_blank" rel="noopener noreferrer" class="hover:text-secondary transition-colors duration-200">Instagram</a>
      <a href="https://www.imdb.com/name/nm4866929" target="_blank" rel="noopener noreferrer" class="hover:text-secondary transition-colors duration-200">IMDb</a>
    </div>

    <div class="flex flex-col gap-3 sm:items-end sm:text-right">
      <span class="text-base-100/30 text-[10px]">Based in</span>
      <span>Brussels, Belgium</span>
      <span class="text-base-100/30 normal-case">&copy; {today.getFullYear()} Victor Maes</span>
    </div>

  </div>
</footer>
