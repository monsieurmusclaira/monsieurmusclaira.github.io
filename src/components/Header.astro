---
const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);
const linkClass = (href: string) =>
  `font-['Montserrat'] text-xs tracking-widest uppercase transition-colors duration-200 ${
    isActive(href) ? 'text-secondary' : 'text-base-100 hover:text-secondary'
  }`;
---

<div class="navbar fixed top-0 z-50 bg-black/60 backdrop-blur-xs transition-transform duration-300" id="site-nav">
  <div class="navbar-start">
    <!-- Mobile: hamburger -->
    <div class="dropdown lg:hidden">
      <button class="btn btn-ghost btn-circle" aria-label="Open menu">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="#F1D74E" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7" /></svg>
      </button>
      <ul class="menu menu-sm dropdown-content mt-3 p-2 shadow-sm bg-black/80 backdrop-blur-xs rounded-box w-52 text-base-100">
        <li>
          <a href="/" class={isActive('/') ? 'text-secondary font-semibold' : ''}>Work</a>
        </li>
        <li>
          <a href="/about/" class={isActive('/about') ? 'text-secondary font-semibold' : ''}>About</a>
        </li>
        <li>
          <a href="/about/#contact">Contact</a>
        </li>
      </ul>
    </div>
    <!-- Desktop: inline links -->
    <div class="hidden lg:flex items-center gap-7 pl-3">
      <a href="/" class={linkClass('/')}>Work</a>
      <a href="/about/" class={linkClass('/about')}>About</a>
      <a href="/about/#contact" class="font-['Montserrat'] text-xs tracking-widest uppercase transition-colors duration-200 text-base-100 hover:text-secondary">Contact</a>
    </div>
  </div>

  <div class="navbar-center">
    <a href="/" class="font-['Montserrat'] text-sm font-light tracking-widest uppercase text-base-100 hover:text-secondary transition-colors duration-200">
      Victor Maes
    </a>
  </div>

  <div class="navbar-end">
    <div class="flex items-center gap-4 pr-3">
      <a href="https://www.instagram.com/monsieur_musclaira/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="inline-flex items-center h-5 text-base-100/80 hover:text-secondary transition-colors duration-200">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="5" />
          <circle cx="12" cy="12" r="4" />
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
        </svg>
      </a>
      <a href="https://www.imdb.com/name/nm4866929" target="_blank" rel="noopener noreferrer" aria-label="IMDb" class="inline-flex items-center h-5 text-base-100/80 hover:text-secondary transition-colors duration-200">
        <span class="inline-flex items-center h-5 text-[11px] font-bold tracking-tight border border-current rounded-sm px-1.5 leading-none">IMDb</span>
      </a>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var nav = document.getElementById('site-nav');
    var lastY = 0;
    var ticking = false;

    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(function () {
          var y = window.scrollY;
          if (y > lastY && y > 80) {
            nav.style.transform = 'translateY(-100%)';
          } else {
            nav.style.transform = 'translateY(0)';
          }
          lastY = y;
          ticking = false;
        });
        ticking = true;
      }
    }

    function attachScroll() {
      var nav = document.getElementById('site-nav');
      if (!nav) return;
      lastY = window.scrollY;
      window.removeEventListener('scroll', onScroll);
      window.addEventListener('scroll', onScroll, { passive: true });
    }

    attachScroll();
    document.addEventListener('astro:page-load', function () {
      nav = document.getElementById('site-nav');
      attachScroll();
    });
  })();
</script>
