---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout
  title="Page not found | Victor Maes"
  description="The page you are looking for does not exist."
  noindex={true}
>
  <section class="hero min-h-screen bg-neutral">
    <div class="hero-content flex-col text-center px-6">
      <p class="font-['Montserrat'] text-[11px] tracking-[0.3em] uppercase text-base-100/40 mb-6">Error 404</p>
      <h1 class="font-['EB_Garamond'] text-5xl sm:text-6xl text-secondary mb-5">Page not found</h1>
      <p class="font-['Montserrat'] text-base font-light text-base-100/70 max-w-md mb-10">
        This page has moved, or never existed. Let's get you back to the work.
      </p>
      <a
        href="/"
        class="font-['Montserrat'] text-xs tracking-widest uppercase text-base-100 hover:text-secondary border border-base-100/30 hover:border-secondary rounded-sm px-6 py-3 transition-colors duration-200"
      >
        Back to work
      </a>
    </div>
  </section>
</BaseLayout>
