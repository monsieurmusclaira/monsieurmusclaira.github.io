---
import ProjectCard from './ProjectCard.astro';
---

<section class="py-24 md:py-32 px-8 md:px-16 lg:px-24 bg-cream">
  <div class="max-w-7xl mx-auto">
    <!-- Section Header -->
    <div class="mb-16 md:mb-24">
      <p class="text-caption text-warmgray mb-4">Selected Work</p>
      <h2 class="text-4xl md:text-5xl text-charcoal max-w-2xl">
        Stories that linger in the spaces between words
      </h2>
    </div>

    <!-- Projects Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
      <ProjectCard
        title="A Long Goodbye"
        img="/img/alonggoodbye/stills/20250709_ALG_Still2.webp"
        desc="co-written & co-directed by Kate Voet & Victor Maes"
        year="2025"
        genre="Virtual Reality"
        url="/projects/a-long-goodbye"
      />

      <ProjectCard
        title="The Tears of Things"
        img="/img/thetearsofthings/stills/TTOT_20212101_1.1.67.png"
        desc="written & directed by Kate Voet"
        year="2021"
        genre="Fiction"
        url="/projects/the-tears-of-things"
      />

      <ProjectCard
        title="Les Homards Immortels"
        img="/img/leshomardsimmortels/stills/KateEditE26_AspectWrapper.01_05_55_23.Still093.png"
        desc="written & directed by Kate Voet"
        year="2017"
        genre="Fiction"
        url="/projects/les-homards-immortels"
      />
    </div>
  </div>
</section>
