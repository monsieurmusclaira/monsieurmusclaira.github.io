---
const today = new Date();
---

<footer class="bg-charcoal text-white/60 py-16 px-8 md:px-16 lg:px-24">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-start md:items-center gap-8">
    <div>
      <p class="text-subtitle text-white/40 mb-2">Kate Voet</p>
      <p class="text-caption text-white/30">Director & Screenwriter</p>
    </div>

    <div class="flex flex-col md:flex-row gap-6 md:gap-12">
      <a href="/" class="text-subtitle text-white/50 hover:text-white transition-colors duration-300 link-underline">
        Work
      </a>
      <a href="/about/" class="text-subtitle text-white/50 hover:text-white transition-colors duration-300 link-underline">
        About
      </a>
      <a href="mailto:hello@katevoet.com" class="text-subtitle text-white/50 hover:text-white transition-colors duration-300 link-underline">
        Contact
      </a>
    </div>

    <p class="text-caption text-white/30">
      &copy; {today.getFullYear()}
    </p>
  </div>
</footer>
